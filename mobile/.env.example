EXPO_PUBLIC_API_BASE_URL=https://produce-ordering-app.onrender.com
EXPO_PUBLIC_APP_ENV=production
EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
# Google Sign-In for Android APKs requires a real Android OAuth client ID from
# Google Cloud / Firebase for package `com.produceordering.app`.
# For local release builds that use `mobile/android/app/debug.keystore`,
# register SHA1 `5E:8F:16:06:2E:A3:CD:2C:4A:0D:54:78:76:BA:A6:F3:8C:AB:F6:25`.
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
APP_VERSION=1.0.0
ANDROID_VERSION_CODE=1
IOS_BUILD_NUMBER=1
