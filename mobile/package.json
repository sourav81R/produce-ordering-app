{
  "name": "produce-ordering-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:apk": "npm exec --yes --package eas-cli@18.8.1 eas -- build -p android --profile production-apk",
    "build:preview-apk": "npm exec --yes --package eas-cli@18.8.1 eas -- build -p android --profile preview",
    "build:android": "npm exec --yes --package eas-cli@18.8.1 eas -- build -p android --profile production",
    "update:preview": "npm exec --yes --package eas-cli@18.8.1 eas -- update --channel preview",
    "update:production": "npm exec --yes --package eas-cli@18.8.1 eas -- update --channel production"
  },
  "expo": {
    "doctor": {
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      },
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-razorpay"
        ]
      }
    }
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.11",
    "axios": "^1.15.1",
    "expo": "~54.0.33",
    "expo-application": "~7.0.8",
    "expo-auth-session": "~7.0.8",
    "expo-crypto": "~15.0.7",
    "expo-linear-gradient": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "firebase": "^12.12.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-razorpay": "^2.3.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0"
  }
}
