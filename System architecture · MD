## 3. Data Models

### User
```js
{
  _id: ObjectId,
  name: String (required),
  email: String (required, unique),
  password: String (hashed, optional for Firebase users),
  firebaseUid: String (optional),
  createdAt: Date
}
```

### Product
```js
{
  _id: ObjectId,
  name: String (required),
  category: Enum ['Vegetable', 'Fruit'],
  price: Number (required),   // per unit
  unit: Enum ['kg', 'piece'],
  createdAt: Date
}
```

### Order
```js
{
  _id: ObjectId,
  retailer: ObjectId (ref: User, required),
  product: ObjectId (ref: Product, required),
  quantity: Number (required, min: 1),
  deliveryDate: Date (required),
  status: Enum ['Pending', 'Confirmed', 'Delivered'], default: 'Pending',
  createdAt: Date
}
```

